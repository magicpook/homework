        // 存储番剧数据到localStorage
        function saveAnimeList() {
            localStorage.setItem('animeList', JSON.stringify(animeList));
        }
        
        // 从localStorage加载番剧数据
        function loadAnimeList() {
            const saved = localStorage.getItem('animeList');
            if (saved) {
                animeList = JSON.parse(saved);
            }
        }
        
        // 生成番剧卡片
        function generateAnimeCards() {
            const animeGrid = document.getElementById('anime-grid');
            animeGrid.innerHTML = '';
            
            animeList.forEach(anime => {
                const card = document.createElement('div');
                card.className = 'card scroll-reveal';
                card.innerHTML = `
                    <div class="card-img">
                        <img src="${anime.image}" alt="${anime.title}" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">${anime.title}</h3>
                        <p class="card-text">${anime.season} | ${anime.episodes}集 | ${anime.status}</p>
                        <a href="#" class="btn view-detail" data-id="${anime.id}">查看详情</a>
                    </div>
                `;
                animeGrid.appendChild(card);
            });
            
            // 添加查看详情事件
            document.querySelectorAll('.view-detail').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const animeId = parseInt(this.getAttribute('data-id'));
                    showAnimeDetail(animeId);
                });
            });
        }
        
        // 显示番剧详情
        function showAnimeDetail(animeId) {
            const anime = animeList.find(a => a.id === animeId);
            if (!anime) return;
            
            // 隐藏其他部分，显示详情页
            document.getElementById('anime').style.display = 'none';
            document.getElementById('games').style.display = 'none';
            document.getElementById('about').style.display = 'none';
            document.getElementById('contact').style.display = 'none';
            document.getElementById('anime-detail').style.display = 'block';
            
            // 填充详情数据
            document.querySelector('.anime-title').textContent = anime.title;
            document.querySelector('.anime-meta').innerHTML = `
                <span>季度: ${anime.season}</span>
                <span>集数: ${anime.episodes}</span>
                <span>状态: ${anime.status}</span>
            `;
            document.querySelector('.anime-description').textContent = anime.description;
            
            // 显示番剧图片
            const animePoster = document.querySelector('.anime-poster');
            animePoster.innerHTML = `<img src="${anime.image}" alt="${anime.title}" style="width: 100%; height: 100%; object-fit: cover; border-radius: 10px;">`;
            
            // 存储当前查看的番剧ID
            document.getElementById('edit-anime-id').value = anime.id;
            
            // 编辑按钮事件
            document.querySelector('.edit-btn').addEventListener('click', function() {
                document.querySelector('.edit-form').style.display = 'block';
                
                // 填充编辑表单
                document.getElementById('edit-title').value = anime.title;
                document.getElementById('edit-season').value = anime.season;
                document.getElementById('edit-episodes').value = anime.episodes;
                document.getElementById('edit-status').value = anime.status;
                document.getElementById('edit-description').value = anime.description;
            });
        }
        
        // 返回列表
        document.querySelector('.back-btn a').addEventListener('click', function(e) {
            e.preventDefault();
            
            // 显示番剧列表，隐藏详情页
            document.getElementById('anime').style.display = 'block';
            document.getElementById('games').style.display = 'block';
            document.getElementById('about').style.display = 'block';
            document.getElementById('contact').style.display = 'block';
            document.getElementById('anime-detail').style.display = 'none';
            
            // 隐藏编辑表单
            document.querySelector('.edit-form').style.display = 'none';
        });
        
        // 取消编辑
        document.querySelector('.cancel-edit').addEventListener('click', function() {
            document.querySelector('.edit-form').style.display = 'none';
        });
        
        // 保存编辑
        document.getElementById('edit-anime-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const animeId = parseInt(document.getElementById('edit-anime-id').value);
            const animeIndex = animeList.findIndex(a => a.id === animeId);
            
            if (animeIndex !== -1) {
                animeList[animeIndex] = {
                    id: animeId,
                    title: document.getElementById('edit-title').value,
                    season: document.getElementById('edit-season').value,
                    episodes: parseInt(document.getElementById('edit-episodes').value),
                    status: document.getElementById('edit-status').value,
                    description: document.getElementById('edit-description').value
                };
                
                // 保存到localStorage
                saveAnimeList();
                
                // 更新详情页
                showAnimeDetail(animeId);
                
                // 隐藏编辑表单
                document.querySelector('.edit-form').style.display = 'none';
                
                // 重新生成番剧卡片
                generateAnimeCards();
                
                alert('番剧信息已更新！');
            }
        });
        
        // 移动端菜单切换
        const menuToggle = document.querySelector('.menu-toggle');
        const navLinks = document.querySelector('.nav-links');
        
        menuToggle.addEventListener('click', () => {
            navLinks.classList.toggle('active');
        });
        
        // 平滑滚动
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                const targetElement = document.querySelector(targetId);
                
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 70,
                        behavior: 'smooth'
                    });
                    
                    // 关闭移动端菜单
                    navLinks.classList.remove('active');
                }
            });
        });
        
        // 滚动显示效果
        function handleScrollReveal() {
            const elements = document.querySelectorAll('.scroll-reveal');
            
            elements.forEach(element => {
                const elementTop = element.getBoundingClientRect().top;
                const elementVisible = 150;
                
                if (elementTop < window.innerHeight - elementVisible) {
                    element.classList.add('active');
                }
            });
        }
        
        window.addEventListener('scroll', handleScrollReveal);
        
        // 表单提交
        document.querySelector('.contact-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            // 获取表单数据
            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const message = document.getElementById('message').value;
            
            // 模拟表单提交
            alert(`感谢您的留言，${name}！我们会尽快回复您。`);
            
            // 重置表单
            this.reset();
        });
        
        // 卡片悬停效果
        document.querySelectorAll('.card').forEach(card => {
            card.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-10px)';
            });
            
            card.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0)';
            });
        });
        
        // 刷新列表
        document.querySelector('.refresh-btn').addEventListener('click', function() {
            loadAnimeList();
            generateAnimeCards();
            alert('番剧列表已刷新！');
        });
        
        // 添加番剧
        document.querySelector('.add-anime-btn').addEventListener('click', function() {
            document.querySelector('.add-anime-form').style.display = 'block';
        });
        
        // 取消添加
        document.querySelector('.cancel-add').addEventListener('click', function() {
            document.querySelector('.add-anime-form').style.display = 'none';
        });
        
        // 保存新番剧
        document.getElementById('add-anime-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const newAnime = {
                id: Date.now(), // 使用时间戳作为唯一ID
                title: document.getElementById('add-title').value,
                season: document.getElementById('add-season').value,
                episodes: parseInt(document.getElementById('add-episodes').value),
                status: document.getElementById('add-status').value,
                description: document.getElementById('add-description').value
            };
            
            animeList.push(newAnime);
            
            // 保存到localStorage
            saveAnimeList();
            
            // 重新生成番剧卡片
            generateAnimeCards();
            
            // 隐藏添加表单
            document.querySelector('.add-anime-form').style.display = 'none';
            
            // 重置表单
            this.reset();
            
            alert('番剧已添加！');
        });
        
        // 留言板功能
        let messages = [
            {
                id: 1,
                author: '动漫迷小王',
                content: '你的网站设计得太棒了！二次元风格超级赞，配色也很舒服~',
                date: '2024-01-20'
            },
            {
                id: 2,
                author: '星野爱',
                content: '我也超喜欢雷姆！同好握手🤝 期待看到更多你的作品！',
                date: '2024-01-18'
            },
            {
                id: 3,
                author: '游戏玩家A',
                content: '原神玩家+1，可以一起联机吗？UID: 123456789',
                date: '2024-01-15'
            }
        ];
        
        // 存储留言到localStorage
        function saveMessages() {
            localStorage.setItem('messages', JSON.stringify(messages));
        }
        
        // 从localStorage加载留言
        function loadMessages() {
            const saved = localStorage.getItem('messages');
            if (saved) {
                messages = JSON.parse(saved);
            }
        }
        
        // 生成留言列表
        function generateMessages() {
            const messagesList = document.getElementById('messages-list');
            messagesList.innerHTML = '';
            
            messages.forEach(message => {
                const messageItem = document.createElement('div');
                messageItem.className = 'message-item';
                messageItem.innerHTML = `
                    <div class="message-header">
                        <span class="message-author">${message.author}</span>
                        <span class="message-date">${message.date}</span>
                    </div>
                    <div class="message-content">${message.content}</div>
                `;
                messagesList.appendChild(messageItem);
            });
        }
        
        // 提交留言
        document.getElementById('guestbook-form').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const newMessage = {
                id: Date.now(),
                author: document.getElementById('guest-name').value,
                content: document.getElementById('guest-message').value,
                date: new Date().toISOString().split('T')[0]
            };
            
            messages.unshift(newMessage); // 添加到列表开头
            
            // 保存到localStorage
            saveMessages();
            
            // 重新生成留言列表
            generateMessages();
            
            // 重置表单
            this.reset();
            
            alert('留言已提交！');
        });
        
        // 初始化
        function init() {
            loadAnimeList();
            generateAnimeCards();
            loadMessages();
            generateMessages();
            handleScrollReveal();
        }
        
        // 页面加载完成后初始化
        window.addEventListener('DOMContentLoaded', init);
    </script>
</body>
</html>
