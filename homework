<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>二次元世界 - 个人网站</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --primary-color: #8A70C9;
            --secondary-color: #B794F6;
            --accent-color: #6B56A8;
            --background-color: #1A1D2E;
            --text-color: #F0E6FF;
            --card-color: #2A3042;
            --hover-color: #3A4052;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--background-color);
            color: var(--text-color);
            line-height: 1.6;
            background-image: url('data:image/svg+xml;base64,');
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        /* 导航栏 */
        header {
            background-color: rgba(26, 29, 46, 0.95);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.3);
        }
        
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 0;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .logo-img {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            font-weight: bold;
            box-shadow: 0 0 15px rgba(107, 144, 199, 0.5);
        }
        
        .logo-text {
            font-size: 24px;
            font-weight: bold;
            color: var(--text-color);
            text-shadow: 0 0 10px rgba(139, 184, 232, 0.5);
        }
        
        .nav-links {
            display: flex;
            list-style: none;
            gap: 2rem;
        }
        
        .nav-links a {
            color: var(--text-color);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }
        
        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--secondary-color);
            transition: width 0.3s ease;
        }
        
        .nav-links a:hover::after {
            width: 100%;
        }
        
        .nav-links a:hover {
            color: var(--secondary-color);
            text-shadow: 0 0 10px rgba(139, 184, 232, 0.5);
        }
        
        /* 移动端菜单 */
        .menu-toggle {
            display: none;
            font-size: 24px;
            cursor: pointer;
        }
        
        /* 英雄区域 */
        .hero {
            padding: 6rem 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        
        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(107, 144, 199, 0.2), rgba(74, 111, 165, 0.2));
            z-index: -1;
        }
        
        .hero h1 {
            font-size: 4rem;
            margin-bottom: 1rem;
            color: var(--text-color);
            text-shadow: 0 0 20px rgba(139, 184, 232, 0.5);
        }
        
        .hero p {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            color: var(--text-color);
            opacity: 0.9;
        }
        
        .btn {
            display: inline-block;
            padding: 12px 30px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(107, 144, 199, 0.3);
        }
        
        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(107, 144, 199, 0.5);
        }
        
        /* 内容区域 */
        .content {
            padding: 4rem 0;
        }
        
        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 3rem;
            color: var(--text-color);
            position: relative;
        }
        
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 100px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
        }
        
        /* 卡片网格 */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }
        
        .card {
            background-color: var(--card-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        
        .card-img {
            width: 100%;
            height: 200px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: white;
        }
        
        .card-content {
            padding: 1.5rem;
        }
        
        .card-title {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .card-text {
            color: var(--text-color);
            opacity: 0.8;
            margin-bottom: 1.5rem;
        }
        
        /* 关于区域 */
        .about {
            background-color: rgba(42, 48, 66, 0.5);
            padding: 4rem 0;
            margin: 4rem 0;
        }
        
        .about-content {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        
        .about-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
            width: 100%;
            max-width: 600px;
        }
        
        .stat-item {
            background-color: var(--card-color);
            padding: 1.5rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
        }
        
        .stat-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
        }
        
        .stat-value {
            display: block;
            font-size: 2rem;
            font-weight: bold;
            color: var(--secondary-color);
            margin-bottom: 0.5rem;
        }
        
        .stat-label {
            display: block;
            font-size: 0.9rem;
            color: var(--text-color);
            opacity: 0.8;
        }
        
        .about-info {
            margin-top: 1rem;
            text-align: left;
            max-width: 600px;
            width: 100%;
            background-color: var(--card-color);
            padding: 1.5rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .about-info p {
            margin-bottom: 0.5rem;
        }
        
        .about-info strong {
            color: var(--secondary-color);
        }
        
        .about-img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: white;
            margin-bottom: 2rem;
            box-shadow: 0 0 20px rgba(107, 144, 199, 0.5);
        }
        
        /* 番剧列表 */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        .action-buttons {
            display: flex;
            gap: 1rem;
        }
        
        .add-anime-form {
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            margin-top: 2rem;
        }
        
        .add-anime-form h3 {
            margin-bottom: 1.5rem;
            color: var(--text-color);
        }
        
        /* 番剧详情页 */
        .back-btn {
            margin-bottom: 2rem;
        }
        
        .anime-detail-content {
            display: flex;
            gap: 2rem;
            margin-bottom: 3rem;
        }
        
        .anime-poster {
            width: 300px;
            height: 450px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: white;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }
        
        .anime-info {
            flex: 1;
        }
        
        .anime-title {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .anime-meta {
            display: flex;
            gap: 2rem;
            margin-bottom: 2rem;
            color: var(--text-color);
            opacity: 0.8;
        }
        
        .anime-description {
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 2rem;
            color: var(--text-color);
        }
        
        .anime-actions {
            display: flex;
            gap: 1rem;
        }
        
        .edit-form {
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .edit-form h3 {
            margin-bottom: 1.5rem;
            color: var(--text-color);
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .anime-detail-content {
                flex-direction: column;
                align-items: center;
            }
            
            .anime-poster {
                width: 250px;
                height: 375px;
            }
            
            .anime-title {
                font-size: 2rem;
                text-align: center;
            }
            
            .anime-meta {
                flex-direction: column;
                gap: 0.5rem;
                text-align: center;
            }
        }
        
        /* 追番列表区域 */
        .anime-list-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }
        
        .anime-list-item {
            background-color: var(--card-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            display: flex;
            align-items: center;
            padding: 1.5rem;
        }
        
        .anime-list-item:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        
        .anime-list-img {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            margin-right: 1.5rem;
        }
        
        .anime-list-info {
            flex: 1;
        }
        
        .anime-list-title {
            font-size: 1.3rem;
            margin-bottom: 0.5rem;
            color: var(--text-color);
        }
        
        .anime-list-genre {
            font-size: 0.9rem;
            color: var(--text-color);
            opacity: 0.8;
            margin-bottom: 0.3rem;
        }
        
        .anime-list-rating {
            font-size: 0.9rem;
            color: var(--secondary-color);
            font-weight: bold;
            margin-bottom: 0.3rem;
        }
        
        .anime-list-status {
            font-size: 0.9rem;
            color: var(--text-color);
            opacity: 0.8;
        }
        
        /* 兴趣爱好区域 */
        .hobbies-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }
        
        .hobby-card {
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .hobby-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        
        .hobby-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .hobby-title {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .hobby-description {
            color: var(--text-color);
            opacity: 0.8;
        }
        
        /* 作品展示区域 */
        .works-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }
        
        .work-card {
            background-color: var(--card-color);
            border-radius: 10px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .work-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }
        
        .work-img {
            width: 100%;
            height: 200px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: white;
        }
        
        .work-card .card-content {
            padding: 1.5rem;
        }
        
        .work-title {
            font-size: 1.5rem;
            margin-bottom: 1rem;
            color: var(--text-color);
        }
        
        .work-description {
            color: var(--text-color);
            opacity: 0.8;
        }
        
        /* 留言板区域 */
        .section-description {
            text-align: center;
            margin-bottom: 3rem;
            font-size: 1.1rem;
            color: var(--text-color);
            opacity: 0.8;
        }
        
        .guestbook-content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
        }
        
        .messages-container {
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .messages-container h3,
        .message-form h3 {
            margin-bottom: 1.5rem;
            color: var(--text-color);
        }
        
        #messages-list {
            max-height: 400px;
            overflow-y: auto;
        }
        
        .message-item {
            background-color: var(--background-color);
            padding: 1.5rem;
            border-radius: 10px;
            margin-bottom: 1rem;
            border-left: 4px solid var(--secondary-color);
        }
        
        .message-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        
        .message-author {
            font-weight: bold;
            color: var(--secondary-color);
        }
        
        .message-date {
            font-size: 0.8rem;
            color: var(--text-color);
            opacity: 0.6;
        }
        
        .message-content {
            color: var(--text-color);
            line-height: 1.5;
        }
        
        .message-form {
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        /* 联系区域 */
        .contact {
            padding: 4rem 0;
        }
        
        .contact-form {
            max-width: 600px;
            margin: 0 auto;
            background-color: var(--card-color);
            padding: 2rem;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: var(--text-color);
        }
        
        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 10px;
            background-color: var(--background-color);
            border: 1px solid var(--accent-color);
            border-radius: 5px;
            color: var(--text-color);
            transition: all 0.3s ease;
        }
        
        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 10px rgba(139, 184, 232, 0.3);
        }
        
        .form-group textarea {
            resize: vertical;
            min-height: 150px;
        }
        
        /* 页脚 */
        footer {
            background-color: var(--card-color);
            padding: 3rem 0;
            text-align: center;
            margin-top: 4rem;
        }
        
        .footer-content {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        .social-links {
            display: flex;
            gap: 1rem;
            margin: 1rem 0;
        }
        
        .social-links a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background-color: var(--background-color);
            color: var(--text-color);
            transition: all 0.3s ease;
        }
        
        .social-links a:hover {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            transform: translateY(-3px);
        }
        
        /* 响应式设计 */
        @media (max-width: 768px) {
            .nav-links {
                position: fixed;
                top: 70px;
                left: 0;
                width: 100%;
                background-color: var(--card-color);
                flex-direction: column;
                align-items: center;
                padding: 2rem 0;
                gap: 1.5rem;
                transform: translateY(-100%);
                transition: transform 0.3s ease;
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
            }
            
            .nav-links.active {
                transform: translateY(0);
            }
            
            .menu-toggle {
                display: block;
            }
            
            .hero h1 {
                font-size: 2.5rem;
            }
            
            .section-title {
                font-size: 2rem;
            }
        }
        
        /* 动画效果 */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .fade-in {
            animation: fadeIn 0.8s ease forwards;
        }
        
        /* 滚动效果 */
        .scroll-reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease;
        }
        
        .scroll-reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <!-- 导航栏 -->
    <header>
        <div class="container navbar">
            <div class="logo">
                <div class="logo-img">🌟</div>
                <div class="logo-text">二次元世界</div>
            </div>
            <ul class="nav-links">
                <li><a href="#home">首页</a></li>
                <li><a href="#anime">动漫</a></li>
                <li><a href="#games">游戏</a></li>
                <li><a href="#about">关于</a></li>
                <li><a href="#contact">联系</a></li>
            </ul>
            <div class="menu-toggle">☰</div>
        </div>
    </header>
    
    <!-- 英雄区域 -->
    <section id="home" class="hero">
        <div class="container">
            <h1 class="fade-in">欢迎来到二次元世界</h1>
            <p class="fade-in">探索动漫、游戏和二次元文化的精彩内容</p>
            <a href="#anime" class="btn fade-in">开始探索</a>
        </div>
    </section>
    
    <!-- 动漫区域 -->
    <section id="anime" class="content">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title scroll-reveal">热门番剧</h2>
                <div class="action-buttons">
                    <button class="btn refresh-btn">刷新列表</button>
                    <button class="btn add-anime-btn">添加番剧</button>
                </div>
            </div>
            <div class="card-grid" id="anime-grid">
                <!-- 番剧卡片将通过JavaScript动态生成 -->
            </div>
            <div class="add-anime-form" style="display: none;">
                <h3>添加新番剧</h3>
                <form id="add-anime-form">
                    <div class="form-group">
                        <label for="add-title">标题</label>
                        <input type="text" id="add-title" required>
                    </div>
                    <div class="form-group">
                        <label for="add-season">季度</label>
                        <input type="text" id="add-season">
                    </div>
                    <div class="form-group">
                        <label for="add-episodes">集数</label>
                        <input type="number" id="add-episodes">
                    </div>
                    <div class="form-group">
                        <label for="add-status">状态</label>
                        <select id="add-status">
                            <option value="连载中">连载中</option>
                            <option value="已完结">已完结</option>
                            <option value="未开播">未开播</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="add-description">简介</label>
                        <textarea id="add-description" rows="5"></textarea>
                    </div>
                    <button type="submit" class="btn">添加番剧</button>
                    <button type="button" class="btn cancel-add">取消</button>
                </form>
            </div>
        </div>
    </section>
    
    <!-- 番剧详情页 -->
    <section id="anime-detail" class="content" style="display: none;">
        <div class="container">
            <div class="back-btn"><a href="#anime" class="btn">返回列表</a></div>
            <div class="anime-detail-content">
                <div class="anime-poster"></div>
                <div class="anime-info">
                    <h2 class="anime-title"></h2>
                    <div class="anime-meta"></div>
